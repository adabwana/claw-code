# Copy to `.env` in this directory and fill in values. `.env` is gitignored.
#
# OpenRouter (uses the OpenAI-compatible Chat Completions API).
# Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # default; override only if needed

# Default model when you omit `--model` (any OpenRouter model id, e.g. anthropic/claude-3.5-sonnet).
CLAW_MODEL=qwen/qwen3.6-plus:free

# Direct Anthropic access (optional — leave unset to use OpenRouter for everything).
# ANTHROPIC_API_KEY=sk-ant-...
